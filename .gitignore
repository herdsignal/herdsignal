# ── 환경변수 (절대 커밋 금지) ─────────────────
.env
backups/
*.env
.env.*
!.env.example

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# ── Node.js ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 빌드 산출물 ───────────────────────────────
dist/
build/
*.class
*.jar

# ── Gradle ────────────────────────────────────
.gradle/
!gradle/wrapper/gradle-wrapper.jar

# ── IDE ───────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.vscode/
*.swp
*.swo

# ── OS ────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db

# ── 로그 ──────────────────────────────────────
*.log
logs/

# ── 재현 가능한 연구 산출물 (manifest 포함 로컬 보관) ──
data/snapshots/*
!data/snapshots/README.md
data/walk_forward/*
!data/walk_forward/README.md
