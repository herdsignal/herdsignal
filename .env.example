# .env.example — 실제 값 없이 키만 정의한 예시 파일
# 이 파일을 복사해 .env로 이름을 바꾼 뒤 실제 값을 채워 사용하세요.
# .env 파일은 절대 Git에 커밋하지 마세요.

# ── Finnhub API ────────────────────────────────
# 무료 플랜 발급: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── MariaDB 접속 정보 ──────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=herdsignal
DB_PASSWORD=your_password_here
DB_NAME=herdsignal

# ── yfinance 수집 설정 ────────────────────────
# 기간 포맷: 1d / 5d / 1mo / 3mo / 6mo / 1y / 2y / 5y / 10y / ytd / max
YFINANCE_PERIOD=5y
MIN_HISTORY_YEARS=2

# ── Frontend API 설정 ─────────────────────────
# 개발: 비워두면 Vite proxy(/api → localhost:8080)를 사용
# 프로덕션: 실제 API 서버 URL 지정
VITE_API_BASE_URL=
VITE_AUTH_BASE_URL=http://localhost:8080

# ── Google 로그인 ─────────────────────────────
# 로컬 개발은 false면 기존 local 사용자로 실행됩니다.
AUTH_ENABLED=false
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FRONTEND_URL=http://localhost:5173
# 기존 local 포트폴리오를 이 Google 계정에 한 번 연결합니다.
HERDSIGNAL_OWNER_EMAIL=your_google_email@gmail.com
# 서버 세션은 마지막 사용 후 30일, 브라우저 쿠키는 최대 180일 유지합니다.
SESSION_IDLE_TIMEOUT=30d
SESSION_COOKIE_MAX_AGE=180d
# HTTPS 배포 환경에서는 반드시 true
SESSION_COOKIE_SECURE=false

# ── HERD Index 가중치 (합계 = 1.0, v4 운영 기준) ─────
WEIGHT_MONTHLY_RSI=0.24
WEIGHT_WEEKLY_RSI=0.19
WEIGHT_52W_POSITION=0.19
WEIGHT_MA200_DEV=0.18
WEIGHT_VOLUME=0.00
WEIGHT_MA200_WEEKLY=0.20

# ── HERD 히스토리 백필 ─────────────────────────
HERD_BACKFILL_YEARS=3
HERD_BACKFILL_FREQ=weekly
HERD_BACKFILL_SOURCE_PERIOD=10y

# ── 차세대 HERD Shadow Mode ───────────────────
# 사전 채택 기준과 단일 Blind holdout을 통과하기 전에는 false를 유지합니다.
HERD_SHADOW_ENABLED=false
HERD_SHADOW_CANDIDATE_ID=
HERD_SHADOW_HOLDOUT_PASSED=false

# ── 로깅 ─────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# ── 로컬 DB 백업 ─────────────────────────────
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14

# ── 스케줄러 장애 알림 ───────────────────────
# Slack/Discord 등 수신 가능한 웹훅 URL. 비워두면 전송하지 않습니다.
ALERT_WEBHOOK_URL=
ALERT_NOTIFY_SUCCESS=false
ALERT_TIMEOUT_SECONDS=5
