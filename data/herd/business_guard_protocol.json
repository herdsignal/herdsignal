{
  "protocol_version": "2026.07-sec-pit-business-guard-v1",
  "status": "LOCKED_BEFORE_OOS_RESULTS",
  "objective": "Test whether blocking an add-buy when point-in-time business fundamentals deteriorate reduces subsequent downside without creating a sell signal.",
  "data_contract": {
    "source": "SEC_COMPANYFACTS_WITH_SUBMISSIONS_ACCEPTANCE_TIMES",
    "allowed_forms": ["10-K", "10-K/A", "10-Q", "10-Q/A"],
    "allowed_taxonomies": ["us-gaap"],
    "monetary_unit": "USD",
    "availability_time": "SEC_ACCEPTANCE_DATETIME",
    "amendment_rule": "LATEST_ACCEPTED_VALUE_FOR_IDENTICAL_CONCEPT_AND_PERIOD",
    "duration_days_quarterly_minimum": 70,
    "duration_days_quarterly_maximum": 120,
    "duration_days_annual_minimum": 300,
    "duration_days_annual_maximum": 400,
    "maximum_fact_age_days": 550,
    "restatement_backfill_forbidden": true
  },
  "features": {
    "REVENUE": {
      "comparison": "LATEST_QUARTER_VS_PRIOR_YEAR_QUARTER",
      "deterioration": "YOY_GROWTH_LTE_NEGATIVE_10_PERCENT"
    },
    "EARNINGS": {
      "comparison": "NET_INCOME_MARGIN_VS_PRIOR_YEAR_QUARTER",
      "deterioration": "NET_LOSS_OR_MARGIN_DROP_GTE_5_PERCENTAGE_POINTS"
    },
    "OPERATING_CASH_FLOW": {
      "comparison": "LATEST_ANNUAL_OR_TTM_WHEN_RECONSTRUCTABLE",
      "deterioration": "NON_POSITIVE_OR_YOY_DROP_GTE_30_PERCENT"
    },
    "DEBT_BURDEN": {
      "comparison": "LIABILITIES_TO_ASSETS_VS_PRIOR_YEAR",
      "deterioration": "RATIO_GTE_60_PERCENT_AND_INCREASE_GTE_10_PERCENTAGE_POINTS"
    }
  },
  "guard_rule": {
    "VETO": [
      "AT_LEAST_TWO_DETERIORATION_FLAGS",
      "OR_NET_LOSS_AND_NON_POSITIVE_OPERATING_CASH_FLOW"
    ],
    "PASS": ["ZERO_OR_ONE_DETERIORATION_FLAG"],
    "UNKNOWN": ["REQUIRED_COMPARABLE_FACTS_UNAVAILABLE_OR_STALE"],
    "research_unknown_policy": "EXCLUDE_FROM_PREDICTIVE_COMPARISON",
    "live_unknown_policy": "DO_NOT_AUTHORIZE_ADD_BUY"
  },
  "predictive_test": {
    "forward_horizons_months": [3, 6, 12],
    "outcomes": ["FORWARD_TOTAL_RETURN", "FORWARD_TROUGH_RETURN"],
    "primary_horizon_months": 6,
    "event_sampling": "FIRST_MONTH_OF_GUARD_STATE_TRANSITION",
    "inference_sample": "NON_OVERLAPPING_EVENTS_WITHIN_TICKER_AND_HORIZON",
    "purge_rule": "OUTCOME_MUST_END_INSIDE_TEST_FOLD"
  },
  "adoption_gate": {
    "minimum_events_per_side": 30,
    "minimum_test_folds_per_side": 4,
    "minimum_directional_folds": 4,
    "maximum_holm_p_value": 0.1,
    "required_primary_outcomes": 2,
    "veto_must_have_lower_forward_return": true,
    "veto_must_have_lower_forward_trough": true
  },
  "action_ablation": {
    "candidate_events": "FLEE_OR_SCATTER_ADD_BUY_ONLY",
    "comparison": "SAME_ADD_BUY_RULE_WITH_VS_WITHOUT_BUSINESS_GUARD",
    "execution": "NEXT_TRADING_DAY_OPEN",
    "add_buy_size": 0.05,
    "maximum_equity_exposure": 1.0,
    "minimum_equity_exposure": 0.85,
    "base_one_way_fee": 0.001,
    "base_one_way_slippage": 0.0005,
    "stress_one_way_fee": 0.002,
    "stress_one_way_slippage": 0.0015
  },
  "forbidden": [
    "BUSINESS_GUARD_CHANGES_HERD_SCORE",
    "BUSINESS_GUARD_CREATES_SELL_SIGNAL",
    "UNKNOWN_TREATED_AS_DETERIORATED_IN_PREDICTIVE_TEST",
    "FUTURE_RESTATEMENT_BACKFILL",
    "THRESHOLD_SEARCH_AFTER_RESULTS"
  ]
}
