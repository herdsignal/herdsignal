    },
    {
      "id": "T_PARTICIPATION",
      "family": "PARTICIPATION",
      "standalone_test": "OOS_CONFIRMATION_EVENT_STUDY",
      "action_test": "PRICE_EXTENSION_AND_TREND_GATED_ABLATION",
