    "initial_exposure": 1.0,
    "default_exposure": 0.9,
    "minimum_exposure": 0.85,
    "maximum_exposure": 1.0,
    "maximum_monthly_change": 0.15,
    "base_one_way_fee": 0.001,
    "base_one_way_slippage": 0.0005,
