    "multiple_testing": "HOLM_WITHIN_FAMILY_HORIZONS",
    "maximum_adjusted_p_value": 0.1,
    "inference_sample": "NON_OVERLAPPING_MONTHLY_CROSS_SECTIONAL_RANK_IC"
  },
  "tests": [
    {
      "id": "T_PRICE_EXTENSION",
      "family": "PRICE_EXTENSION",
      "standalone_test": "OOS_MONOTONIC_BUCKET_AND_RANK_IC",
      "action_test": "NONE",
      "reason": "Extension alone cannot trigger profit-taking."
    },
    {
      "id": "T_TREND_MATURITY",
      "family": "TREND_MATURITY",
      "standalone_test": "OOS_CONTINUATION_AND_DECELERATION_EVENT_STUDY",
