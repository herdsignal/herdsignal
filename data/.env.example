# .env.example — 실제 값 없이 키만 정의한 예시 파일
# 이 파일을 복사해 .env 로 이름을 바꾼 뒤 실제 값을 채워 사용하세요.
# .env 파일은 절대 Git에 커밋하지 마세요.

# ── Finnhub API ────────────────────────────────
# 무료 플랜 발급: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── MariaDB 접속 정보 ──────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=herdsignal
DB_PASSWORD==herdsignal1234
DB_NAME=herdsignal

# ── yfinance 수집 설정 ────────────────────────
# 기간 포맷: 1d / 5d / 1mo / 3mo / 6mo / 1y / 2y / 5y / 10y / ytd / max
YFINANCE_PERIOD=5y
MIN_HISTORY_YEARS=2

# ── HERD Index 가중치 (합계 = 1.0, v2: 6개 지표) ─────
WEIGHT_MONTHLY_RSI=0.20
WEIGHT_WEEKLY_RSI=0.18
WEIGHT_52W_POSITION=0.18
WEIGHT_MA200_DEV=0.14
WEIGHT_VOLUME=0.10
WEIGHT_MA200_WEEKLY=0.20

# ── 로깅 ─────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
